# ── Kontaktformular (SMTP / nodemailer) ──
# Trage diese Werte bei deinem Hosting/Mail-Provider ein.
# Lokal: kopiere diese Datei nach `.env.local` und fülle die Werte aus.
# Auf Vercel: Project Settings → Environment Variables.

SMTP_HOST=smtp.example.com      # z. B. smtp.gmail.com, asmtp.mail.hostpoint.ch …
SMTP_PORT=587                   # 587 (STARTTLS) oder 465 (SSL)
SMTP_USER=info@unfoldcreativestudio.ch
SMTP_PASS=dein-app-passwort     # App-Passwort / Mailbox-Passwort
CONTACT_TO=info@unfoldcreativestudio.ch   # Empfänger der Anfragen (optional)
